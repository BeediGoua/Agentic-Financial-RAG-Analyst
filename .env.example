# Environment configuration for Agentic Financial RAG Analyst
# Copy this to .env and adjust values as needed

# Ollama Configuration (if using Ollama)
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# HuggingFace Configuration (if using HuggingFace API)
HUGGINGFACE_API_KEY=hf_your_token_here_XXXXXXXXXXXXXXXXXXXXXXXX

# Default LLM Provider (ollama or huggingface)
LLM_PROVIDER=ollama

# Data paths
DATA_RAW_DIR=data/raw
DATA_LOGS_DIR=data/logs
DATA_METADATA_DIR=data/metadata

# Ingestion defaults
DEFAULT_MAX_PAGES=5
DEFAULT_LIMIT=10

# BRVM scraping configuration
BRVM_TIMEOUT=60
BRVM_LISTING_PAGES=2
BRVM_REQUEST_DELAY=1

# Logging
LOG_LEVEL=INFO
